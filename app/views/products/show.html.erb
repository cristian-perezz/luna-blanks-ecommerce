<div class="max-w-5xl mx-auto px-4 py-10">
  <%= link_to "← Back to Shop", products_path, class: "text-l text-gray-300 hover:text-white mb-6 inline-block" %>

  <div class="bg-white rounded-3xl p-8 mt-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

  <div>
    <% if @product.images.attached? %>
      <div class="rounded-2xl overflow-hidden bg-gray-50">
        <%= image_tag @product.images.first, class: "w-full object-contain max-h-96", id:"main-image" %>
      </div>


        <% if @product.images.count > 1 %>
          <div class="flex gap-3 mt-4">
            <% @product.images.each do |img| %>
              <img src="<%= url_for(img) %>"
                class="w-24 h-24 object-cover rounded-xl border-2 border-transparent hover:border-black cursor-pointer transition-all"
                onclick="document.getElementById('main-image').src = this.src" />
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="flex flex-col justify-start gap-4">
      <h1 class="text-3xl font-bold text-gray-900"><%= @product.name %></h1>
      <p class="text-2xl font-semibold text-gray-800">$<%= @product.price %></p>
      <div class="text-gray-600 text-sm leading-relaxed">
        <%= @product.description %>
      </div>

      <%# SIZE %>
        <div class="mt-2">
          <h3 class="text-sm font-semibold mb-2">Sizes</h3>
          <div class="flex flex-wrap gap-3 mt-2">
            <% ["S", "M", "L", "XL"].each do |size| %>
              <button type="button"
                onclick="selectSize(this, '<%= size %>')"
                class="size-btn px-4 py-1 border border-gray-300 text-sm font-medium transition hover:bg-gray-100">
                <%= size %>
              </button>
            <% end %>
          </div>
          <p id="size-error" class="text-red-500 text-xs mt-2 hidden">Please select a size before adding to cart.</p>
        </div>

        <%# ADD TO CART %>
        <%= form_with url: cart_add_path, method: :post, id: "add-to-cart-form" do |f| %>
          <%= hidden_field_tag :product_id, @product.id %>
          <%= hidden_field_tag :size, "", id: "selected-size" %>
          <%= f.submit "Add to Cart",
                class: "mt-4 bg-black text-white text-sm px-6 py-3 rounded-xl hover:bg-gray-800 transition-colors w-full text-center cursor-pointer" %>
        <% end %>

      </div>
    </div>
  </div>
</div>

<script>
  function selectSize(btn, size) {
    // Remove highlight from all size buttons
    document.querySelectorAll(".size-btn").forEach(b => {
      b.classList.remove("bg-black", "text-white", "border-black");
      b.classList.add("border-gray-300");
    });

    btn.classList.add("bg-black", "text-white", "border-black");
    btn.classList.remove("border-gray-300");

    document.getElementById("selected-size").value = size;

    document.getElementById("size-error").classList.add("hidden");
  }

  document.getElementById("add-to-cart-form").addEventListener("submit", function(e) {
    const size = document.getElementById("selected-size").value;
    if (!size) {
      e.preventDefault();
      document.getElementById("size-error").classList.remove("hidden");
    }
  });
</script>