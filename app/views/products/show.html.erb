<div class="max-w-5xl mx-auto px-4 py-10">
  <%= link_to "← Back to Shop", products_path, class: "text-l text-gray-300 hover:text-white mb-6 inline-block" %>

  <div class="bg-white rounded-3xl p-8 mt-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

  <div>
    <% if @product.images.attached? %>
      <div class="rounded-2xl overflow-hidden bg-gray-50">
        <%= image_tag @product.images.first, class: "w-full object-contain max-h-96", id:"main-image" %>
      </div>


        <% if @product.images.count > 1 %>
          <div class="flex gap-3 mt-4">
            <% @product.images.each do |img| %>
              <img src="<%= url_for(img) %>"
                class="w-24 h-24 object-cover rounded-xl border-2 border-transparent hover:border-black cursor-pointer transition-all"
                onclick="document.getElementById('main-image').src = this.src" />
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="flex flex-col justify-start gap-4">
      <h1 class="text-3xl font-bold text-gray-900"><%= @product.name %></h1>
      <p class="text-2xl font-semibold text-gray-800">$<%= @product.price %></p>
      <div class="text-gray-600 text-sm leading-relaxed">
        <%= @product.description %>
      </div>

      <div class="mt-2">
        <h3 class="text-sm font-semibold mb-2">Sizes</h3>

        <div class ="flex flex-wrap gap-3 mt-2">
          <% ["S", "M", "L", "XL"].each do |size| %>
            <label class="cursor-pointer">
              <input type="radio" name="size" value="<%= size %>" class="peer hidden", style="display: none">

              <div class="px-4 py-1 text-center flex items-center justify-center border border-gray-300 text-sm font-medium cursor-pointer transition hover:bg-gray-100
                  peer-checked:bg-blue-100 peer-checked:text-black peer-checked:border-blue-100">
                <%= size %>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <%= button_to "Add to Cart", cart_add_path(product_id: @product.id),
            method: :post,
            class: "mt-4 bg-black text-white text-sm px-6 py-3 rounded-xl hover:bg-gray-800 transition-colors w-full text-center" %>
    </div>
  </div>
</div>