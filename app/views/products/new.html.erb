<div class="max-w-2xl mx-auto p-6 bg-white rounded-2xl">
  <h1 class="text-2xl font-bold mb-4">Add New Product</h1>

  <%= form_with model: @product, local: true do |f| %>

    <div class="mb-4">
      <%= f.label :name %>
      <%= f.text_field :name, class: "w-full border p-2 rounded" %>
    </div>

    <div class="mb-4">
      <%= f.label :price %>
      <%= f.number_field :price, step: 0.01, class: "w-full border p-2 rounded" %>
    </div>

    <div class="mb-4">
      <%= f.label :description %>
      <%= f.text_area :description, class: "w-full border p-2 rounded" %>
    </div>

    <div class="mb-4">
      <%= f.label :images %>
      <%= f.file_field :images, multiple: true, class: "w-full" %>
    </div>


    <%= f.submit "Create Product", class: "bg-black text-white px-4 py-2 rounded" %>
    <%= yield %>
  <% end %>
</div>